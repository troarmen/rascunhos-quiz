# Variáveis de ambiente do quiz.
# No Vercel: Project > Settings > Environment Variables (NÃO comite o .env real).
# Para rodar/local com `vercel dev`, copie este arquivo para .env e preencha.

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (Settings > API). Só no servidor.

# Brevo (opcional — adiciona o e-mail à lista automaticamente)
BREVO_API_KEY=xkeysib-...
BREVO_LIST_ID=5
